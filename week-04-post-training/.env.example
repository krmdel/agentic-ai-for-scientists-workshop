# Week 4 — environment template. Copy to .env (local) or add as Colab Secrets.
# Only NB00 (dataset prep) needs a key. The training notebooks (01-04) need only a GPU.

# REQUIRED for NB00 — free, no card: https://aistudio.google.com/apikey
# The Gemini labeler that turns MedQuAD answers into structured clinical JSON.
GOOGLE_API_KEY=AIza...

# OPTIONAL — push your prepared dataset / trained models to the Hugging Face Hub.
# https://huggingface.co/settings/tokens  (a "write" token)
HF_TOKEN=hf_...

# OPTIONAL — swap the NB00 labeler from Gemini to Claude (edit one cell).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
