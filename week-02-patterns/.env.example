# Week 2 — environment variables
# Copy to .env and fill in the keys you have. Notebooks check each key before
# using it and fall back to a free local alternative when possible.

# REQUIRED for all four notebooks
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — only if you want OpenAI embeddings in Notebook 03 instead of the
# free local sentence-transformers model. The notebook auto-detects and prefers
# the local model when this key is absent.
OPENAI_API_KEY=sk-...

# OPTIONAL — Notebook 04 (Elasticsearch appendix) only. Sign up for a free
# 14-day trial at https://cloud.elastic.co and find these in your deployment
# dashboard under "Endpoints" + "Security → API keys".
ELASTIC_CLOUD_ID=...
ELASTIC_API_KEY=...
