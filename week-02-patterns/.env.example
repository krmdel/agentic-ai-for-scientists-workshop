# Week 2 — environment variables
# Copy to .env and fill in the keys you have. Notebooks check each key first and
# fall back to a free local alternative when possible.

# REQUIRED — free Gemini key, no credit card: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# OPTIONAL — real agent web search (free 1,000/mo): https://app.tavily.com
TAVILY_API_KEY=tvly-...

# OPTIONAL — agent tracing (free Developer plan): https://smith.langchain.com
LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_TRACING_V2=true

# OPTIONAL — OpenAI embeddings in Notebook 03 instead of the free local model.
OPENAI_API_KEY=sk-...

# OPTIONAL — Notebook 04 (Elasticsearch appendix) only. Free 14-day trial:
# https://cloud.elastic.co  (find these under Endpoints + Security -> API keys)
ELASTIC_CLOUD_ID=...
ELASTIC_API_KEY=...
