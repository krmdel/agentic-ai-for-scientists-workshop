flowchart LR
  S([START]):::ghost --> RET["retrieve<br/><span style='font-size:12px;color:#6A6A6A'>top-k from vector store</span>"]:::blue
  RET --> GR{{"grade each doc<br/>relevant?"}}:::coral
  GR -->|all relevant| GEN["generate<br/><span style='font-size:12px;color:#6A6A6A'>answer from context</span>"]:::green
  GR -->|any weak| TR["transform query<br/><span style='font-size:12px;color:#6A6A6A'>rewrite for search</span>"]:::coral
  TR --> WS["web_search<br/><span style='font-size:12px;color:#6A6A6A'>Tavily</span>"]:::coral
  WS --> GEN
  GEN --> E([END]):::ghost
  classDef blue fill:#EAF1F9,stroke:#1F4F8B,stroke-width:2px,color:#1A1A1A;
  classDef green fill:#EAF4EA,stroke:#4A7D3F,stroke-width:2px,color:#1A1A1A;
  classDef coral fill:#F7E9E4,stroke:#C8553D,stroke-width:2px,color:#1A1A1A;
  classDef ghost fill:#F7F8FA,stroke:#B8C0C8,stroke-width:1.5px,color:#6A6A6A;
  classDef model fill:#1F4F8B,stroke:#16386A,stroke-width:2px,color:#FFFFFF;
  classDef hard fill:#4A7D3F,stroke:#356029,stroke-width:2px,color:#FFFFFF;
