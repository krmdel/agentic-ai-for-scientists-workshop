flowchart TB
  subgraph A["single-iterative &nbsp;·&nbsp; one agent, one loop"]
    direction LR
    a1["agent"]:::blue --> a2{{"enough?"}}:::coral --> a1
    a2 -->|"yes"| a3["report"]:::green
  end
  subgraph B["plan-execute &nbsp;·&nbsp; explicit plan, then run"]
    direction LR
    b1["planner"]:::coral --> b2["executor"]:::blue --> b3{{"replan?"}}:::coral --> b2
    b3 -->|"done"| b4["report"]:::green
  end
  subgraph C["supervisor-worker &nbsp;·&nbsp; isolated parallel context"]
    direction LR
    c1["supervisor"]:::coral --> c2["worker pool"]:::blue --> c1
    c1 -->|"synthesise"| c3["report"]:::green
  end
  A ~~~ B ~~~ C
