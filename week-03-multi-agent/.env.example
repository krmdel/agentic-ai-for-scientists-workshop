# Week 3 — environment template. Copy to .env (local) or add as Colab Secrets.
# Only GOOGLE_API_KEY is required; the other two unlock optional features.

# REQUIRED — free, no card: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# OPTIONAL — web-search fallback in Notebook 02 (Agentic RAG). Free 1,000/mo: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# OPTIONAL — tracing/observability. Free Developer plan: https://smith.langchain.com
# NOTE: Week 3 is on the LangGraph 1.x line, which reads the NEW LANGSMITH_* names
# (Week 2 was classic 0.3.x and read LANGCHAIN_*). Use LANGSMITH_API_KEY here.
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=agentic-ai-week3
